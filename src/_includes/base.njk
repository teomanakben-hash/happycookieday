<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ pageTitle or title }}{% if title != site.title %} | {{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ pageDescription or site.description }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css">
  {% if site.under_construction %}
  <style>
    .uc-overlay{position:fixed;top:0;left:0;width:100%;height:100%;z-index:9999;font-family:'DM Sans',sans-serif;background:var(--warm-white);display:flex;flex-direction:column;align-items:center;justify-content:flex-start;overflow-y:auto;overflow-x:hidden;padding:3rem 0}
    body.uc-active{overflow:hidden;height:100vh}
    .uc-overlay::before{content:'';position:fixed;top:0;left:0;width:100%;height:100%;background-image:radial-gradient(circle at 20% 20%,rgba(123,45,59,.03) 0%,transparent 50%),radial-gradient(circle at 80% 80%,rgba(196,149,106,.04) 0%,transparent 50%),radial-gradient(circle at 50% 50%,rgba(123,45,59,.02) 0%,transparent 70%);pointer-events:none;z-index:0}
    .deco{position:fixed;opacity:.06;font-size:3rem;animation:float 12s ease-in-out infinite;pointer-events:none;z-index:0}.deco:nth-child(2){top:10%;left:5%;animation-delay:0s}.deco:nth-child(3){top:60%;right:8%;animation-delay:-3s;font-size:2.5rem}.deco:nth-child(4){bottom:15%;left:12%;animation-delay:-6s;font-size:2rem}.deco:nth-child(5){top:25%;right:15%;animation-delay:-9s;font-size:1.8rem}.deco:nth-child(6){bottom:30%;right:20%;animation-delay:-4s;font-size:2.2rem}
    @keyframes float{0%,100%{transform:translateY(0) rotate(0deg)}33%{transform:translateY(-15px) rotate(5deg)}66%{transform:translateY(10px) rotate(-3deg)}}
    .uc-container{position:relative;z-index:1;text-align:center;padding:2rem;max-width:600px;width:100%}
    .uc-logo{margin-bottom:2.5rem;animation:fadeInDown 1s ease-out}.uc-logo img{width:180px;height:auto;display:block;margin:0 auto;filter:drop-shadow(0 4px 20px rgba(123,45,59,.15));transition:transform .4s ease}.uc-logo img:hover{transform:scale(1.05) rotate(-2deg)}
    .uc-divider{width:60px;height:2px;background:linear-gradient(90deg,transparent,var(--bordo),transparent);margin:0 auto 2rem;animation:fadeIn 1s ease-out .3s both}
    .uc-container h1{font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:600;color:var(--bordo);margin-bottom:.8rem;letter-spacing:-.02em;animation:fadeIn 1s ease-out .4s both}
    .uc-subtitle{font-family:'Playfair Display',serif;font-style:italic;font-size:1.15rem;color:var(--text-light);margin-bottom:2.5rem;font-weight:400;animation:fadeIn 1s ease-out .6s both}
    .uc-contact{background:white;border-radius:20px;padding:2rem 2.5rem;box-shadow:0 1px 3px rgba(123,45,59,.04),0 8px 30px rgba(123,45,59,.06);animation:fadeInUp 1s ease-out .8s both;border:1px solid rgba(123,45,59,.06)}
    .uc-label{font-size:.75rem;text-transform:uppercase;letter-spacing:.15em;color:var(--gold);font-weight:500;margin-bottom:1.2rem}
    .uc-item{display:flex;align-items:center;justify-content:center;gap:.7rem;padding:.7rem 0;color:var(--text);text-decoration:none;font-size:.95rem;transition:color .3s ease;border-bottom:1px solid rgba(123,45,59,.05)}.uc-item:last-child{border-bottom:none}a.uc-item:hover{color:var(--bordo)}
    .uc-icon{width:18px;height:18px;flex-shrink:0;color:var(--bordo-light)}
    .uc-social{display:flex;justify-content:center;gap:1rem;margin-top:2rem;animation:fadeInUp 1s ease-out 1s both}
    .uc-social a{width:44px;height:44px;border-radius:12px;background:var(--cream);display:flex;align-items:center;justify-content:center;color:var(--bordo);text-decoration:none;transition:all .3s ease;border:1px solid rgba(123,45,59,.08)}.uc-social a:hover{background:var(--bordo);color:white;transform:translateY(-3px);box-shadow:0 6px 20px rgba(123,45,59,.2)}.uc-social a svg{width:20px;height:20px}
    .uc-shopier{display:inline-flex;align-items:center;gap:.6rem;margin-top:2rem;padding:.9rem 2rem;background:var(--bordo);color:white;text-decoration:none;border-radius:14px;font-size:.9rem;font-weight:500;transition:all .3s ease;animation:fadeInUp 1s ease-out 1.1s both;box-shadow:0 4px 15px rgba(123,45,59,.2)}.uc-shopier:hover{background:var(--bordo-dark);transform:translateY(-2px);box-shadow:0 8px 25px rgba(123,45,59,.3);color:white}.uc-shopier svg{width:18px;height:18px}
    .uc-footer{position:relative;z-index:1;margin-top:3rem;padding-bottom:2rem;animation:fadeIn 1s ease-out 1.3s both}.uc-footer p{font-size:.75rem;color:var(--text-light);opacity:.6}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}@keyframes fadeInDown{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}@keyframes fadeInUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    @media(max-width:480px){.uc-container h1{font-size:1.7rem}.uc-subtitle{font-size:1rem}.uc-contact{padding:1.5rem}.uc-logo img{width:140px}}
    .uc-hidden{display:none!important}
  </style>
  {% endif %}
  </head>
<body{% if site.under_construction %} class="uc-active"{% endif %}>
  {% if site.under_construction %}
  <div class="uc-overlay" id="ucOverlay">
    <div class="deco">🍪</div>
    <div class="deco">🎂</div>
    <div class="deco">🧁</div>
    <div class="deco">🍪</div>
    <div class="deco">🎂</div>
    <div class="uc-container">
      <div class="uc-logo">
        <img src="/assets/images/logo.png" alt="{{ site.title }}">
      </div>
      <div class="uc-divider"></div>
      <h1>Yakında Sizlerleyiz</h1>
      <p class="uc-subtitle">Lezzetli sürprizlerle çok yakında buradayız</p>
      <div class="uc-contact">
        <div class="uc-label">Bize Ulaşın</div>
        <a href="tel:{{ site.phone | replace(' ', '') }}" class="uc-item">
          <svg class="uc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>{{ site.phone }}</span>
        </a>
        {% if site.whatsapp %}
        <a href="https://wa.me/{{ site.whatsapp }}" target="_blank" rel="noopener" class="uc-item">
          <svg class="uc-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span>0532 478 52 90 (WhatsApp)</span>
        </a>
        {% endif %}
        <a href="mailto:{{ site.email }}" class="uc-item">
          <svg class="uc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span>{{ site.email }}</span>
        </a>
      </div>
      <div class="uc-social">
        {% if site.instagram %}<a href="{{ site.instagram }}" title="Instagram" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>{% endif %}
        {% if site.facebook %}<a href="{{ site.facebook }}" title="Facebook" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>{% endif %}
        {% if site.whatsapp %}<a href="https://wa.me/{{ site.whatsapp }}" title="WhatsApp" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></a>{% endif %}
      </div>
      <a href="{{ site.shopier_url }}" class="uc-shopier" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        Shopier'den Sipariş Ver
      </a>
    </div>
    <div class="uc-footer"><p>&copy; 2025 {{ site.title }}. Tüm hakları saklıdır.</p></div>
  </div>
  <script>
    (function(){
      var params = new URLSearchParams(window.location.search);
      if(params.get('preview')==='true'){
        sessionStorage.setItem('hcd_preview','true');
      }
      if(sessionStorage.getItem('hcd_preview')==='true'){
        var ov = document.getElementById('ucOverlay');
        if(ov) ov.classList.add('uc-hidden');
        document.body.classList.remove('uc-active');
      }
    })();
  </script>
  {% endif %}

  {% include "partials/header.njk" %}
  <main class="main">
    {{ content | safe }}
  </main>
  {% include "partials/footer.njk" %}

</body>
</html>
