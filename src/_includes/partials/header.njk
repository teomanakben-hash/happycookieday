<header class="header">
  <div class="header-top">
    <div class="container header-top-inner">
      <div class="header-contact">
        <a href="tel:{{ site.phone | replace(' ', '') }}" class="header-contact-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {{ site.phone }}
        </a>
        <a href="mailto:{{ site.email }}" class="header-contact-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          {{ site.email }}
        </a>
      </div>
      <div class="header-social">
        {% if site.instagram %}
        <a href="{{ site.instagram }}" target="_blank" rel="noopener" title="Instagram" class="social-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        {% endif %}
        {% if site.facebook %}
        <a href="{{ site.facebook }}" target="_blank" rel="noopener" title="Facebook" class="social-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        {% endif %}
        {% if site.whatsapp %}
        <a href="https://wa.me/{{ site.whatsapp }}" target="_blank" rel="noopener" title="WhatsApp" class="social-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="header-main">
    <div class="container header-main-inner">
      <a href="/" class="logo">
        <img src="/assets/images/logo.png" alt="{{ site.title }}" width="120" height="auto">
      </a>

      <!-- Mobile menu toggle -->
      <button class="mobile-toggle" aria-label="Menüyü aç" onclick="document.querySelector('.nav').classList.toggle('nav--open')">
        <span></span><span></span><span></span>
      </button>

      <nav class="nav">
        <ul class="nav-list">
          <li class="nav-item"><a href="/" class="nav-link">Ana Sayfa</a></li>

          {%- set topCategories = collections.allCategories | topLevel -%}
          {%- for cat in topCategories -%}
            {%- set subCats = collections.allCategories | byParent(cat.fileSlug) -%}
            <li class="nav-item{% if subCats.length %} nav-item--has-children{% endif %}">
              <a href="/kategori/{{ cat.fileSlug }}/" class="nav-link">{{ cat.data.title }}</a>
              {%- if subCats.length %}
              <ul class="nav-dropdown">
                {%- for sub in subCats %}
                <li><a href="/kategori/{{ sub.fileSlug }}/" class="nav-dropdown-link">{{ sub.data.title }}</a></li>
                {%- endfor %}
              </ul>
              {%- endif %}
            </li>
          {%- endfor -%}

          {% if site.shopier_url %}
          <li class="nav-item">
            <a href="{{ site.shopier_url }}" target="_blank" rel="noopener" class="nav-link nav-link--shopier">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              Sipariş Ver
            </a>
          </li>
          {% endif %}
        </ul>
      </nav>
    </div>
  </div>
</header>
