---
layout: base.njk
title: Happy Cookie Day
pageTitle: Happy Cookie Day | Özel Tasarım Kurabiye & Pasta
---

<!-- Hero -->
<section class="hero">
  <div class="container">
    <h1 class="hero-title">Happy Cookie Day</h1>
    <p class="hero-subtitle">Özel tasarım kurabiyeler, pastalar ve tatlılar</p>
    {% if site.shopier_url %}
    <a href="{{ site.shopier_url }}" target="_blank" rel="noopener" class="hero-btn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      Sipariş Ver
    </a>
    {% endif %}
  </div>
</section>

<!-- Featured Products -->
{% set featuredProducts = collections.allProducts | selectattr("data.featured") | selectattr("data.active") %}
{% if featuredProducts | length %}
<section class="section">
  <div class="container">
    <h2 class="section-title">Öne Çıkanlar</h2>
    <p class="section-subtitle">En beğenilen ürünlerimiz</p>
    <div class="product-grid">
      {% for product in featuredProducts %}
      <div class="product-card">
        {% if product.data.images and product.data.images[0] %}
        <div class="product-card-img">
          <img src="{{ product.data.images[0].image or product.data.images[0] }}" alt="{{ product.data.title }}" loading="lazy">
        </div>
        {% endif %}
        <div class="product-card-body">
          <h3 class="product-card-title">{{ product.data.title }}</h3>
          {% if product.data.price %}
          <p class="product-card-price">{{ product.data.price }}</p>
          {% endif %}
          {% if product.data.shopier_url %}
          <a href="{{ product.data.shopier_url }}" target="_blank" rel="noopener" class="product-card-btn">
            Sipariş Ver
          </a>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Categories -->
{% set topCategories = collections.allCategories | topLevel %}
{% if topCategories | length %}
<section class="section" style="background: var(--cream);">
  <div class="container">
    <h2 class="section-title">Kategoriler</h2>
    <p class="section-subtitle">Tüm ürün kategorilerimizi keşfedin</p>
    <div class="category-grid">
      {% for cat in topCategories %}
      {% if cat.data.active !== false %}
      <a href="/kategori/{{ cat.fileSlug }}/" class="category-card">
        {% if cat.data.image %}
        <div class="category-card-img">
          <img src="{{ cat.data.image }}" alt="{{ cat.data.title }}" loading="lazy">
        </div>
        {% endif %}
        <div class="category-card-body">
          <h3 class="category-card-title">{{ cat.data.title }}</h3>
          {% if cat.data.description %}
          <p class="category-card-desc">{{ cat.data.description }}</p>
          {% endif %}
        </div>
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
